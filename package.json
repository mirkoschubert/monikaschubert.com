{
	"name": "monikaschubert.com",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:push:prod": "dotenv -e .env.production -- drizzle-kit push",
		"db:migrate:prod": "dotenv -e .env.production -- drizzle-kit migrate",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"release": "zsh scripts/release.sh"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@fontsource-variable/inter": "^5.2.8",
		"@inlang/paraglide-js": "^2.10.0",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.7.0",
		"@neondatabase/serverless": "^1.0.2",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^22",
		"better-auth": "~1.5.6",
		"bits-ui": "^2.16.4",
		"clsx": "^2.1.1",
		"dotenv-cli": "^11.0.0",
		"drizzle-kit": "^0.31.8",
		"drizzle-orm": "^0.45.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vercel": "^50.37.3",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0"
	},
	"dependencies": {
		"@better-auth/passkey": "^1.5.6",
		"postgres": "^3.4.8"
	}
}
