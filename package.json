{
  "name": "monikaschubert.com",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push:prod": "dotenv -e .env.production -- drizzle-kit push",
    "db:migrate:prod": "dotenv -e .env.production -- drizzle-kit migrate",
    "auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
    "release": "zsh scripts/release.sh"
  },
  "devDependencies": {
    "@better-auth/cli": "~1.4.21",
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@inlang/paraglide-js": "^2.10.0",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^0.577.0",
    "@neondatabase/serverless": "^1.0.2",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/dompurify": "^3.2.0",
    "@types/marked": "^6.0.0",
    "@types/node": "^22",
    "better-auth": "~1.5.6",
    "bits-ui": "^2.16.4",
    "clsx": "^2.1.1",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "eslint": "^10.2.0",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.2",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vercel": "^50.37.3",
    "vite": "^7.3.1",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@prisma/client",
      "better-sqlite3"
    ]
  },
  "dependencies": {
    "@better-auth/passkey": "^1.5.6",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@lezer/highlight": "^1.2.3",
    "@lukulent/svelte-umami": "^0.0.4",
    "@vercel/blob": "^2.3.2",
    "codemirror": "^6.0.2",
    "isomorphic-dompurify": "^3.7.1",
    "marked": "^17.0.5",
    "marked-footnote": "^1.4.0",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  }
}
